# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=magicuser
DB_PASSWORD=magicpass
DB_NAME=magicgourmet

# Seguridad
JWT_SECRET=change_me_to_a_strong_secret_in_production

# API
PORT=4000

# Frontend
NEXT_PUBLIC_API_BASE_URL=/api
API_INTERNAL_URL=http://api:4000

# Email SMTP (para confirmaciones y recordatorios de reservas)
# Gmail: habilita "Contraseñas de aplicación" en tu cuenta Google
# Mailtrap (desarrollo): https://mailtrap.io
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_aqui
SMTP_FROM="MagicGourmet <noreply@magicgourmet.cl>"
RESTAURANT_NAME=MagicGourmet
